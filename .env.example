# Copy this file to .env and fill in your values.
# The app will work without a .env file (defaults to SQLite + a dev key),
# but you should set a real SECRET_KEY for any non-local deployment.

SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///swim.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@host:5432/dbname

FLASK_DEBUG=true
